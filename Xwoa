-- [[ Osama Ultra-Light Hub v5 ]] --
local ScreenGui = Instance.new("ScreenGui", game.Players.LocalPlayer:WaitForChild("PlayerGui"))
local Frame = Instance.new("Frame", ScreenGui)
Frame.Size = UDim2.new(0, 200, 0, 200)
Frame.Position = UDim2.new(0.2, 0, 0.2, 0)
Frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
Frame.Active = true
Frame.Draggable = true

-- زر Steal Mail
local MailBtn = Instance.new("TextButton", Frame)
MailBtn.Size = UDim2.new(0, 180, 0, 40)
MailBtn.Position = UDim2.new(0, 10, 0, 20)
MailBtn.Text = "STEAL MAIL"
MailBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
MailBtn.TextColor3 = Color3.fromRGB(255, 255, 255)

-- زر Coins
local CoinBtn = Instance.new("TextButton", Frame)
CoinBtn.Size = UDim2.new(0, 180, 0, 40)
CoinBtn.Position = UDim2.new(0, 10, 0, 80)
CoinBtn.Text = "ADD COINS (VISUAL)"
CoinBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 0)
CoinBtn.TextColor3 = Color3.fromRGB(255, 255, 255)

-- منطق الأزرار (بدون دوال معقدة لضمان عدم التعليق)
MailBtn.MouseButton1Click:Connect(function()
    MailBtn.Text = "EXECUTING..."
    -- هنا سنضع الإرسال لاحقاً إذا اشتغل هذا الجزء
    task.wait(1)
    MailBtn.Text = "DONE!"
    task.wait(1)
    MailBtn.Text = "STEAL MAIL"
end)

CoinBtn.MouseButton1Click:Connect(function()
    local stats = game.Players.LocalPlayer:FindFirstChild("leaderstats")
    if stats then
        for _, v in pairs(stats:GetChildren()) do
            if string.find(string.lower(v.Name), "coin") or string.find(string.lower(v.Name), "money") then
                v.Value = 999999
            end
        end
    end
    CoinBtn.Text = "COINS SET!"
    task.wait(1)
    CoinBtn.Text = "ADD COINS (VISUAL)"
end)
